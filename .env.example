LUNA_DATA_ROOT=/Users/pieratradio/LunaData
LUNA_MODEL_PROVIDER=whooshd
LUNA_MODEL_NAME=
LUNA_MODEL_BASE_URL=http://127.0.0.1:8000/v1
LUNA_SERVER_HOST=0.0.0.0
LUNA_SERVER_PORT=7777

# Email channel SMTP (read by luna.channels.email.config.SmtpConfig.from_env)
# Real values go in .env (gitignored), NOT in source.
#
# Two auth modes are supported:
#   1. App password (simple — works for any SMTP server that accepts
#      PLAIN/LOGIN; Gmail requires an "app password" generated at
#      https://myaccount.google.com/apppasswords)
#   2. OAuth2 XOAUTH2 (recommended for Gmail; modern, more secure).
#      Run scripts/email_bootstrap_oauth.py once to capture the
#      refresh_token, then save it below.
#
# OAuth wins when both modes are configured.

LUNA_EMAIL_SMTP_HOST=
LUNA_EMAIL_SMTP_PORT=587
LUNA_EMAIL_SMTP_SECURITY=starttls
LUNA_EMAIL_SMTP_USERNAME=

# App password auth (mode 1)
LUNA_EMAIL_SMTP_PASSWORD=

# OAuth2 XOAUTH2 auth (mode 2) — set all four for OAuth
LUNA_EMAIL_OAUTH_CLIENT_ID=
LUNA_EMAIL_OAUTH_CLIENT_SECRET=
LUNA_EMAIL_OAUTH_REFRESH_TOKEN=
LUNA_EMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.send

LUNA_EMAIL_FROM_ADDRESS=

# Web research tools (search_web / fetch_webpage).
# Missing configuration does NOT block startup: search_web reports
# "unavailable" and fetch_webpage still works. Real values go in .env.
LUNA_WEB_SEARCH_PROVIDER=none
LUNA_SEARXNG_URL=
LUNA_BRAVE_SEARCH_API_KEY=
